{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja"
    },
    {
      "name": "default",
      "inherits": "base",
      "binaryDir": "${sourceDir}/../../../../out/cmake/p0-hello/default"
    },
    {
      "name": "no-app",
      "inherits": "default",
      "binaryDir": "${sourceDir}/../../../../out/cmake/p0-hello/no-app",
      "cacheVariables": {
        "HELLO_BUILD_APP": "OFF"
      }
    },
    {
      "name": "windows-default",
      "inherits": "default",
      "binaryDir": "${sourceDir}/../../../../out/cmake/p0-hello/windows-default",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "debug",
      "inherits": "default",
      "binaryDir": "${sourceDir}/../../../../out/cmake/p0-hello/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }    },
    {
      "name": "release",
      "inherits": "default",
      "binaryDir": "${sourceDir}/../../../../out/cmake/p0-hello/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "no-app",
      "configurePreset": "no-app"
    },
    {
      "name": "windows-default",
      "configurePreset": "windows-default"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ]
}